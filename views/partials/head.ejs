<script>
  // Runs immediately while HTML parses to prevent FOUC (Flash of Unstyled Content)
  const savedTheme = localStorage.getItem('mandos-theme') || 'tokyo-night-storm';
  document.documentElement.className = `theme-${savedTheme}`; 
  // Note: if you apply the class to <body> instead of <html>, change the above line to:
  // document.write(`<body class="theme-${savedTheme}">`); 
</script>